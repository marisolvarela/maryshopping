		{
			"name": "authentication",
			"item": [
				{
					"name": "get_customer_token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Verificar que la respuesta es 200",
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Parsear el JSON de la respuesta",
									"const jsonResponse = pm.response.json();",
									"",
									"// Extraer los valores del JSON y guardarlos en variables de entorno",
									"pm.environment.set(\"accessToken\", jsonResponse.accessToken);",
									"pm.environment.set(\"refreshToken\", jsonResponse.refreshToken);",
									"pm.environment.set(\"tokenType\", jsonResponse.tokenType);",
									"pm.environment.set(\"expiresIn\", jsonResponse.expiresIn);",
									"",
									"// Opcional: mostrar un mensaje en consola confirmando que se guardaron",
									"console.log(\"✅ Tokens guardados en variables de entorno\");",
									"console.log(\"accessToken: \" + jsonResponse.accessToken);",
									"console.log(\"refreshToken: \" + jsonResponse.refreshToken);",
									"console.log(\"tokenType: \" + jsonResponse.tokenType);",
									"console.log(\"expiresIn: \" + jsonResponse.expiresIn);",
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
